{
    "pulseaudio": {
        "format": "<span rise='1.5pt'>{icon}</span> {volume}%"
    },
    "tray": {
        "icon-size": 20
    },
    "clock": {
        "format": "{:%H:%M}"
    },
    "bluetooth": {
        "format-connected": " {device_alias}",
        "format-no-controller": "",
        "format-on": "",
        "on-click": "blueman-manager"
    },
    "include": "/etc/xdg/waybar/config.jsonc"
}
